#!/bin/sh
set -e

if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload || true

    # On upgrade, restart only when service is already active.
    if [ "${1:-}" = "configure" ] && [ -n "${2:-}" ]; then
        if systemctl is-active --quiet auretty.service; then
            systemctl try-restart auretty.service || true
        fi
    fi
fi

exit 0
