[Unit]
Description=AureTTY terminal runtime service
Documentation=https://github.com/vitkuz573/AureTTY
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/auretty/auretty.env
ExecStart=/usr/lib/auretty/AureTTY
Restart=on-failure
RestartSec=2s
KillSignal=SIGINT
TimeoutStopSec=20s
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
